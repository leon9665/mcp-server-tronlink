# ============================================
# mcp-server-tronlink Environment Variables Reference
# ============================================
# This file is for reference only and is NOT read by the server.
# All variables must be injected via the env field in MCP JSON config:
#
#   .mcp.json (Claude Code project-level)
#   claude_desktop_config.json (Claude Desktop)
#   settings.json (Claude Code global)
#
# Minimum config (.mcp.json) — wallet auto-generated on first launch:
#   {
#     "mcpServers": {
#       "tronlink": {
#         "command": "node",
#         "args": ["dist/index.js"],
#         "env": {
#           "TL_TRONGRID_URL": "https://nile.trongrid.io"
#         }
#       }
#     }
#   }

# ── TronLink Extension ──────────────────────────────
# TronLink extension build directory (containing manifest.json)
# Leave empty for auto-detection: ./dist, ../tronlink-extension-pro/dist, etc.
TRONLINK_EXTENSION_PATH=

# TronLink extension source directory (enables tl_build capability)
# Leave empty to disable build capability
TRONLINK_SOURCE_PATH=

# ── Runtime Mode ─────────────────────────────────────
# Working mode: e2e (local test chain) or prod (real network)
TL_MODE=prod

# Run browser in headless mode (true/false)
TL_HEADLESS=false

# Playwright slow motion in milliseconds (for debugging, 0 = normal speed)
TL_SLOW_MO=0

# ── TronGrid API (On-chain Operations) ──────────────
# TronGrid full node API URL
# Testnet: https://nile.trongrid.io
# Mainnet: https://api.trongrid.io
TL_TRONGRID_URL=

# TronGrid API Key (not required for Nile/Shasta, required for mainnet)
# How to apply:
#   1. Visit https://www.trongrid.io/
#   2. Register / sign in to your TronGrid account
#   3. Go to Dashboard → Create API Key
#   4. Free quota: 100,000 requests/day (sufficient for development & testing)
#   5. Paste the generated key below
TL_TRONGRID_API_KEY=

# ── Wallet Configuration (via @bankofai/agent-wallet) ──
# Private keys are managed securely by agent-wallet with encrypted local storage.
# Keys are encrypted at rest — never stored as plain text in config.
#
# Zero-config: If no wallet exists, the server auto-generates one on first launch.
# A random password is saved to ~/.agent-wallet/runtime_secrets.json.
#
# Manual setup (optional): set a specific password to use a wallet you created.
#   1. agent-wallet start local_secure --generate --wallet-id main
#   2. Set AGENT_WALLET_PASSWORD below (must match the password used above)
AGENT_WALLET_PASSWORD=
#
# Runtime wallet management via MCP tools:
#   tl_wallet_list        — list all wallets
#   tl_wallet_set_active  — switch active wallet
#
# CLI wallet management:
#   agent-wallet list              — list all wallets
#   agent-wallet use <id>          — set active wallet
#   agent-wallet inspect <id>      — show wallet details
#
# Optional: custom config directory (default: ~/.agent-wallet)
# WARNING: Do not delete runtime_secrets.json — it contains the password
#          needed to decrypt existing wallets.
AGENT_WALLET_DIR=

# ── Multi-wallet Setup (Optional) ────────────────────
# For multisig operations, you can configure additional wallets by their
# wallet ID in agent-wallet. Use `agent-wallet list` to see available IDs.
#
# Owner wallet ID for multisig permission updates (defaults to main wallet)
TL_OWNER_WALLET_ID=
# Co-signer wallet ID for multisig signing
TL_COSIGNER_WALLET_ID=

# ── Multisig Service (Optional) ─────────────────────
# Configure the following 4 items to enable tl_multisig_* tools (5 tools)
# Testnet: https://apinile.walletadapter.org
# Mainnet: https://api.walletadapter.org
TL_MULTISIG_BASE_URL=

# Multisig service credentials
# How to apply:
#   1. Contact the TronLink team to request multisig service credentials
#   2. Or use Nile testnet default credentials (for development & testing only):
#      SECRET_ID=TEST  SECRET_KEY=TESTTESTTEST  CHANNEL=test
#   3. Production use requires formal application (see tron-multi-sig project README)
TL_MULTISIG_SECRET_ID=
TL_MULTISIG_SECRET_KEY=
TL_MULTISIG_CHANNEL=

# ── SunSwap (Optional) ───────────────────────────────
# SunSwap V2 Router contract address (for tl_chain_swap)
# Mainnet: TKzxdSv2FZKQrEqkKVgp5DcwEXBEKMg2Ax
# Nile testnet may not have SunSwap deployed; leave empty to disable swap
TL_SUNSWAP_ROUTER=

# SunSwap Smart Router contract address (for tl_chain_swap_v3, unified V1/V2/V3 routing)
# Source: https://docs.sun.io/developers/swap/smart-router
# Mainnet: TCFNp179Lg46D16zKoumd4Poa2WFFdtqYj
# Nile: TB6xBCixqRPUSKiXb45ky1GhChFJ7qrfFj
# Note: This is the SunSwap unified router that automatically selects the optimal path across V1/V2/V3/PSM/SunCurve pools
TL_SUNSWAP_V3_ROUTER=

# WTRX (Wrapped TRX) contract address
# Mainnet: TNUC9Qb1rRpS5CbWLmNMxXBjyFoydXjWFR (default, no need to set manually)
# Nile: query the SunSwap Router's WETH() method to obtain
# Note: if not set when calling tl_chain_swap_v3, defaults to the mainnet address
TL_WTRX_ADDRESS=

# ── GasFree (Gasless Transfers, Optional) ───────────
# Configure to enable tl_gasfree_* tools (3 tools)
# GasFree allows users to send TRC20 tokens without paying TRX gas fees
#
# GasFree service URL
# Mainnet: https://open.gasfree.io/tron/
# Nile: https://open-test.gasfree.io/nile/
TL_GASFREE_BASE_URL=
#
# GasFree API Key + Secret — how to apply:
#   1. Visit the developer portal: https://developer.gasfree.io/
#   2. Register a developer account (email verification required)
#   3. Create an app → obtain API Key and API Secret
#   4. API specification: https://gasfree.io/specification
#   5. SDK (optional reference): npm install @gasfree/gasfree-sdk
#      GitHub: https://github.com/gasfreeio/gasfree-sdk-js
# Note: Nile testnet also requires a key, but approval is usually quick
TL_GASFREE_API_KEY=
TL_GASFREE_API_SECRET=
